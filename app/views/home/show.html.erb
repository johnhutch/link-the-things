<% content_for :title, "Quartets" %>
<% content_for :body_class, "theme-brutal" %>

<div class="l-container">
  <header class="m-hero-brutal">
    <span class="m-sticker">No login ↗</span>
    <h1 class="m-wordmark"><%= multicolor("Quartets") %></h1>
    <p class="m-lede">Sixteen words. Four hidden groups. Find the threads before you run out of guesses.</p>
  </header>

  <% if @puzzle %>
    <p class="m-hero__nowplaying">Today's pick: <strong><%= @puzzle.title %></strong></p>

    <%= render "play/board", puzzle: @puzzle %>

    <nav class="m-home-nav">
      <%= link_to "Play another →", root_path, class: "m-btn" %>
      <%= link_to "Browse all", play_index_path, class: "m-btn m-btn--pop" %>
    </nav>
  <% else %>
    <div class="m-empty">
      <p>No puzzles featured yet — the board's empty for now.</p>
      <p><%= link_to "Browse all", play_index_path %> · <%= link_to "Sign in", new_user_session_path %> to create one.</p>
    </div>
  <% end %>

  <footer class="m-home-foot"><%= link_to "Sign in", new_user_session_path %></footer>
</div>
